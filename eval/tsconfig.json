{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "..",
    "baseUrl": ".",
    "paths": {
      "@anthropic-ai/sdk": [
        "node_modules/@anthropic-ai/sdk"
      ],
      "openai": [
        "node_modules/openai"
      ],
      "@google/genai": [
        "node_modules/@google/genai"
      ]
    }
  },
  "include": [
    "*.ts",
    "providers/*.ts",
    "panel/**/*.ts",
    "../shared/panel/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
