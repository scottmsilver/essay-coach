rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSharedWith(uid) {
      return exists(/databases/$(database)/documents/shares/$(uid + '_' + request.auth.uid));
    }

    // Convention: config/admins.emails MUST be stored lowercase. This must
    // match isEmailAdmin()'s normalization in functions/src/admins.ts, which
    // lowercases the caller's token email before comparing against this same
    // list — otherwise a mixed-case token email could pass the function gate
    // but be denied here (or vice versa).
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email.lower() in
            get(/databases/$(database)/documents/config/admins).data.emails;
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /essays/{essayId} {
        allow read, write: if request.auth != null
          && (request.auth.uid == uid || isSharedWith(uid));

        match /drafts/{draftId} {
          allow read: if request.auth != null
            && (request.auth.uid == uid || isSharedWith(uid));
          allow create: if request.auth != null
            && (request.auth.uid == uid || isSharedWith(uid))
            && !("evaluation" in request.resource.data);
          allow update: if request.auth != null
            && request.auth.uid == uid
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(["evaluation", "grammarAnalysis", "transitionAnalysis",
                         "promptAnalysis", "coachSynthesis"]);
        }
      }
    }

    match /shares/{shareId} {
      allow read: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid
            || resource.data.sharedWithUid == request.auth.uid
            || resource.data.sharedWithEmail == request.auth.token.email);
      allow create, update, delete: if false;
    }

    // config/admins: only admins may read the admin-emails list itself
    // (isAdmin()'s get() call reads it via rules-internal access, which
    // bypasses these read rules, so this does not create a chicken/egg
    // problem — see functions/src/evalRun.ts's Track-2 audit notes).
    match /config/admins {
      allow read: if isAdmin();
      allow write: if false;
    }

    // config/evalPanel: no client ever reads this (it's only loaded
    // server-side by functions/src/evalRun.ts's loadEvalPanelConfig) — deny
    // all client reads.
    match /config/evalPanel {
      allow read: if false;
      allow write: if false;
    }

    // All other config docs (e.g. config/allowlist, read client-side by
    // src/hooks/useAuth.tsx) keep the original any-authed-user read rule.
    //
    // NOTE: Firestore evaluates overlapping `match` blocks with OR semantics
    // — if ANY matching block's `allow` condition is true, the read is
    // allowed, regardless of what other matching blocks say. Since this
    // wildcard also matches `config/admins` and `config/evalPanel`, its own
    // condition explicitly excludes those doc names so it can't silently
    // re-open the access the two blocks above just closed off.
    match /config/{doc} {
      allow read: if request.auth != null && doc != 'admins' && doc != 'evalPanel';
      allow write: if false;
    }

    match /evalRuns/{runId} {
      allow read: if isAdmin();
      allow write: if false;

      match /items/{itemId} {
        allow read: if isAdmin();
        allow write: if false;
      }
    }

    match /evalGoldLabels/{id} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
